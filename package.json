  ],
  "devDependencies": {
    "turbo": "^2.0.14",
    "@medusajs/eslint-plugin": "2.16.0",
    "eslint": "^9.39.4",
    "prettier": "^3.2.5",
    "jiti": "^2.7.0"
  },
  "overrides": {
    "ajv": "^8.0.0"
  }
}