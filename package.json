{
  "name": "mini-shop-backend",
  "private": true,
  "packageManager": "npm@11.5.2",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "turbo dev --filter=@dtc/backend",
    "build": "turbo build --filter=@dtc/backend",
    "start": "turbo start --filter=@dtc/backend",
    "lint": "turbo lint --filter=@dtc/backend",
